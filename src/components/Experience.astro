---
import jobExperience from '@/data/experience.json'
---

<section id='experience' class="mb-16 scroll-mt-16 md:mb-24 lg:mb-36 lg:scroll-mt-24">

  <!-- Mobile sticky header -->
  <div class="sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:sr-only lg:relative lg:top-auto lg:mx-auto lg:w-full lg:px-0 lg:py-0 lg:opacity-0" style="background-color: rgba(15,23,42,0.85)">
    <h2 class="text-sm font-bold uppercase tracking-widest lg:sr-only" style="color: #e2e8f0">Experiencia</h2>
  </div>

  <ol class="exp-list">
    {jobExperience.map((job) => (
      <li class="mb-12">
        <div class="exp-card group relative grid pb-1 transition-all sm:grid-cols-8 sm:gap-8 md:gap-4">

          <!-- Hover background -->
          <div class="exp-hover absolute -inset-x-4 -inset-y-4 z-0 hidden rounded-md transition lg:-inset-x-6 lg:block"></div>

          <!-- Date column -->
          <header class="z-10 mb-2 mt-1 text-xs font-semibold uppercase tracking-wide sm:col-span-2" style="color: #64748b" aria-label={(job as any).shortDate || job.date}>
            {(job as any).shortDate || job.date}
          </header>

          <!-- Content column -->
          <div class="z-10 sm:col-span-6">
            <h3 class="font-medium leading-snug" style="color: #e2e8f0; font-size: 1rem">
              <a
                href={job.companyUrl || '#'}
                target={job.companyUrl ? '_blank' : undefined}
                rel={job.companyUrl ? 'noopener noreferrer' : undefined}
                class="exp-title-link inline-flex items-baseline font-medium leading-tight"
                style="color: #e2e8f0; font-size: 1rem"
              >
                <span class="absolute -inset-x-4 -inset-y-2.5 hidden rounded md:-inset-x-6 md:-inset-y-4 lg:block"></span>
                <span>
                  {job.title}
                  {job.company && <span style="color: #94a3b8"> · {job.company}</span>}
                  {job.companyUrl && (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="inline-block h-4 w-4 shrink-0 ml-1 translate-y-px" aria-hidden="true"><path fill-rule="evenodd" d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z" clip-rule="evenodd"/></svg>
                  )}
                </span>
              </a>
            </h3>

            <p class="mt-2 text-sm leading-normal" style="color: #94a3b8">{job.description}</p>

            {job.skills && job.skills.length > 0 && (
              <ul class="mt-2 flex flex-wrap" aria-label="Technologies used">
                {job.skills.map((skill: string) => (
                  <li class="mr-1.5 mt-2">
                    <div class="flex items-center rounded-full px-3 py-1 text-xs font-medium leading-5" style="background: rgba(45,212,191,0.10); color: #5eead4">
                      {skill}
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>

        </div>
      </li>
    ))}
  </ol>


</section>

<style>
  .exp-list:hover .exp-card {
    opacity: 0.5;
  }
  .exp-list:hover .exp-card:hover {
    opacity: 1 !important;
  }
  .exp-card:hover .exp-hover {
    background-color: rgba(30, 41, 59, 0.5);
    box-shadow: inset 0 1px 0 0 rgba(148, 163, 184, 0.1);
  }
  .exp-title-link:hover {
    color: #5eead4 !important;
  }
</style>
