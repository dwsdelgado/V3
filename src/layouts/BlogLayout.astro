---
import me from '@/data/me.json'

interface Props {
  title?: string
  description?: string
  wide?: boolean
}
const { title = me.fullName, description = me.description, wide = false } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={me.fullName} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress"></div>
    <div class={`wrapper${wide ? ' wrapper--wide' : ''}`}>
      <header>
        <a href="/blog" class="site-name">{me.fullName}</a>
        <nav>
          <a href={`https://github.com/${me.github}`} target="_blank" rel="noopener">GitHub</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: #f5f5f5;
    color: #111;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
  }

  .wrapper {
    max-width: 760px;
    margin: 2rem auto;
    padding: 2.5rem 2.5rem 4rem;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
  }

  .wrapper--wide { max-width: 1100px; }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .site-name {
    font-weight: 600;
    font-size: 1rem;
    color: #111;
    text-decoration: none;
  }

  .site-name:hover { color: #2563eb; }

  nav a {
    color: #6b7280;
    text-decoration: none;
    font-size: 0.875rem;
  }

  nav a:hover { color: #111; }

  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: #2563eb;
    z-index: 9999;
    transition: width 0.1s linear;
  }

  @keyframes fadein {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .wrapper { animation: fadein 0.3s ease forwards; }

  @media (max-width: 600px) {
    .wrapper { margin: 0; border-radius: 0; border-left: none; border-right: none; padding: 1.5rem 1.25rem 3rem; }
  }
</style>

<script>
  const bar = document.getElementById('scroll-progress')
  if (bar) {
    window.addEventListener('scroll', () => {
      const total = document.documentElement.scrollHeight - window.innerHeight
      const pct = total > 0 ? (window.scrollY / total) * 100 : 0
      bar.style.width = pct + '%'
    }, { passive: true })
  }
</script>
