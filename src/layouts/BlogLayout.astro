---
import me from '@/data/me.json'

interface Props {
  title?: string
  description?: string
}
const { title = me.fullName, description = me.description } = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={me.fullName} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress"></div>
    <div class="wrapper">
      <header>
        <a href="/blog" class="site-name">{me.fullName}</a>
        <nav>
          <a href={`https://github.com/${me.github}`} target="_blank" rel="noopener">GitHub</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: #222222;
    color: #ccc;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    min-height: 100vh;
  }


  .wrapper {
    max-width: 680px;
    margin: 1.5rem auto;
    padding: 2rem 2rem 4rem;
    background: #1a1a1a;
    border: 1px solid #2e2e2e;
    border-radius: 8px;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2rem;
  }

  .site-name {
    font-weight: 600;
    font-size: 1.3rem;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    color: #888;
    text-decoration: none;
    font-size: 0.875rem;
  }

  nav a:hover {
    color: #ccc;
  }

  /* Scroll progress */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: #555;
    z-index: 9999;
    transition: width 0.1s linear;
  }

  /* Fade-in */
  @keyframes fadein {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .wrapper {
    animation: fadein 0.35s ease forwards;
  }
</style>

<script>
  const bar = document.getElementById('scroll-progress')
  if (bar) {
    window.addEventListener('scroll', () => {
      const total = document.documentElement.scrollHeight - window.innerHeight
      const pct = total > 0 ? (window.scrollY / total) * 100 : 0
      bar.style.width = pct + '%'
    }, { passive: true })
  }
</script>
