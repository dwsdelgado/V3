---
import BlogLayout from '@/layouts/BlogLayout.astro'
import { getEntry, render } from 'astro:content'

const { slug } = Astro.params
if (!slug) return Astro.redirect('/blog')

const post = await getEntry('blog', slug) ?? await getEntry('blog', slug + '.md')
if (!post || post.data.draft) return Astro.redirect('/blog')

const { Content, headings } = await render(post)

const kvKey = `views:${slug}`
const kv: KVNamespace | undefined = (Astro.locals as any)?.runtime?.env?.KV

let views = 0
if (kv) {
  const current = await kv.get(kvKey)
  views = current ? parseInt(current) + 1 : 1
  await kv.put(kvKey, views.toString())
}

const wordCount = post.body?.split(/\s+/).filter(Boolean).length ?? 0
const readingTime = Math.max(1, Math.ceil(wordCount / 200))

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3)

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
}

function fmtViews(n: number) {
  return n.toLocaleString('en-US')
}
---

<BlogLayout title={`${post.data.title} — Darwin Delgado`} description={post.data.description} wide={tocHeadings.length > 0}>
  <div class="post-layout">
    <article>
      <h1>{post.data.title}</h1>

      <p class="posted-date">Posted {formatDate(post.data.date)}</p>

      <div class="author-row">
        <img
          src={`https://github.com/dwsdelgado.png?size=64`}
          alt="Darwin Delgado"
          class="avatar"
          width="36"
          height="36"
        />
        <div class="author-info">
          <a href="https://github.com/dwsdelgado" target="_blank" rel="noopener" class="author-name">Darwin Delgado</a>
          <span class="author-meta">{readingTime} min read{views > 0 ? ` · ${fmtViews(views)} views` : ''}</span>
        </div>
      </div>

      <div class='body'>
        <Content />
      </div>

      {post.data.tags?.length > 0 && (
        <div class='post-tags'>
          {post.data.tags.map((tag: string) => (
            <span class='tag'>{tag}</span>
          ))}
        </div>
      )}

      <footer class='post-footer'>
        <a href="/blog" class="back-link">← Back to blog</a>
        {post.data.github_source && (
          <a href={post.data.github_source} target='_blank' rel='noopener' class='source-link'>View source ↗</a>
        )}
      </footer>
    </article>

    {tocHeadings.length > 0 && (
      <aside class="toc">
        <div class="toc-inner">
          <p class="toc-title">Table of contents</p>
          <nav>
            {tocHeadings.map(h => (
              <a
                href={`#${h.slug}`}
                class={`toc-link toc-link--h${h.depth}`}
                data-heading={h.slug}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </div>
      </aside>
    )}
  </div>
</BlogLayout>

<style>
  .post-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 3rem;
  }

  article { color: #374151; min-width: 0; align-self: start; }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #111;
    margin-bottom: 0.75rem;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .posted-date { font-size: 0.9rem; color: #6b7280; margin-bottom: 1.5rem; }

  .author-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; }
  .author-info { display: flex; flex-direction: column; gap: 0.1rem; }
  .author-name { font-size: 0.9rem; font-weight: 600; color: #2563eb; text-decoration: none; }
  .author-name:hover { text-decoration: underline; }
  .author-meta { font-size: 0.78rem; color: #9ca3af; }

  .body :global(p) { margin-bottom: 1.25rem; line-height: 1.8; color: #374151; }
  .body :global(h2) { font-size: 1.35rem; font-weight: 700; color: #111; margin: 2.5rem 0 0.75rem; letter-spacing: -0.01em; }
  .body :global(h3) { font-size: 1.1rem; font-weight: 600; color: #1f2937; margin: 2rem 0 0.5rem; }
  .body :global(a) { color: #2563eb; text-decoration: underline; }
  .body :global(a:hover) { color: #1d4ed8; }
  .body :global(code) { font-family: monospace; font-size: 0.875em; background: #f3f4f6; color: #1f2937; padding: 0.15em 0.4em; border-radius: 4px; }
  .body :global(pre) { position: relative; background: #1e1e2e; color: #cdd6f4; padding: 1.25rem; border-radius: 8px; overflow-x: auto; margin: 1.75rem 0; font-size: 0.875rem; line-height: 1.7; }
  .body :global(pre code) { background: none; padding: 0; color: inherit; }
  .body :global(ul), .body :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .body :global(li) { margin-bottom: 0.375rem; line-height: 1.75; }
  .body :global(blockquote) {
    border-left: 4px solid #2563eb;
    background: #eff6ff;
    padding: 1rem 1.25rem;
    margin: 1.75rem 0;
    border-radius: 0 6px 6px 0;
    color: #374151;
  }
  .body :global(blockquote p) { margin-bottom: 0; }
  .body :global(img) { max-width: 100%; border-radius: 8px; margin: 1.75rem 0; display: block; border: 1px solid #e5e7eb; }
  .body :global(img + em) { display: block; text-align: center; font-size: 0.8rem; color: #9ca3af; margin-top: -1rem; margin-bottom: 1rem; }
  .body :global(hr) { border: none; border-top: 1px solid #e5e7eb; margin: 2rem 0; }

  .body :global(.copy-btn) {
    position: absolute; top: 0.5rem; right: 0.5rem;
    background: #2d2d3f; border: none; color: #9ca3af;
    font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 4px;
    cursor: pointer; font-family: inherit; transition: color 0.15s, background 0.15s;
  }
  .body :global(.copy-btn:hover) { color: #fff; background: #3d3d4f; }
  .body :global(.copy-btn.copied) { color: #6ee7b7; }

  .post-footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 4rem; padding-top: 1.5rem; border-top: 1px solid #e5e7eb; font-size: 0.85rem;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 3rem;
  }

  .tag {
    font-size: 0.75rem;
    color: #6b7280;
    background: #f3f4f6;
    padding: 0.25rem 0.6rem;
    border-radius: 99px;
    font-weight: 500;
  }

  .back-link { color: #6b7280; text-decoration: none; }
  .back-link:hover { color: #111; }
  .source-link { color: #2563eb; text-decoration: none; }
  .source-link:hover { text-decoration: underline; }

  /* TOC */
  .toc { min-width: 0; }
  .toc-inner {
    position: sticky;
    top: 4rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 1.25rem;
  }
  .toc-title { font-size: 0.8rem; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.75rem; }
  .toc-link {
    display: block; font-size: 0.82rem; color: #6b7280; text-decoration: none;
    padding: 0.25rem 0; line-height: 1.4; border-left: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .toc-link--h3 { padding-left: 0.75rem; }
  .toc-link:hover { color: #2563eb; }
  .toc-link.active { color: #2563eb; border-left-color: #2563eb; padding-left: 0.5rem; }
  .toc-link--h3.active { padding-left: 1.25rem; }

  @media (max-width: 900px) {
    .post-layout { grid-template-columns: 1fr; }
    .toc { display: none; }
    h1 { font-size: 1.8rem; }
  }
  @media (max-width: 600px) {
    h1 { font-size: 1.5rem; }
    .post-footer { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>

<script>
  document.querySelectorAll('.body pre').forEach((pre) => {
    const btn = document.createElement('button')
    btn.className = 'copy-btn'
    btn.textContent = 'Copy'
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.innerText ?? ''
      await navigator.clipboard.writeText(code)
      btn.textContent = 'Copied!'
      btn.classList.add('copied')
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied') }, 2000)
    })
    pre.appendChild(btn)
  })

  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
  if (tocLinks.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const link = document.querySelector<HTMLElement>(`.toc-link[data-heading="${entry.target.id}"]`)
        if (link) link.classList.toggle('active', entry.isIntersecting)
      })
    }, { rootMargin: '0px 0px -60% 0px', threshold: 0 })

    tocLinks.forEach(l => {
      const el = document.getElementById(l.dataset.heading ?? '')
      if (el) observer.observe(el)
    })
  }
</script>
